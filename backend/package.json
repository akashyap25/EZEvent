{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "seed": "node scripts/seedDemoData.js",
    "prod:check": "node scripts/prodReadinessCheck.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit",
    "test:integration": "node tests/integration-runner.js",
    "migrate:up": "npx migrate-mongo up",
    "migrate:down": "npx migrate-mongo down",
    "migrate:status": "npx migrate-mongo status",
    "migrate:create": "npx migrate-mongo create",
    "loadtest": "node tests/load-test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.63.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "ical-generator": "^9.0.0",
    "ioredis": "^5.7.0",
    "isomorphic-dompurify": "^2.26.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "migrate-mongo": "^14.0.7",
    "mongodb": "^6.8.0",
    "mongoose": "^8.2.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.3",
    "nodemon": "^3.1.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github": "^1.1.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "passport-twitter": "^0.1.5",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.8.2",
    "socket.io": "^4.8.1",
    "stripe": "^16.5.0",
    "svix": "^1.25.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.9.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.13.1",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.29.7",
    "@babel/node": "^7.28.0",
    "@babel/preset-env": "^7.29.7",
    "@types/jest": "^29.5.8",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "overrides": {
    "passport-oauth": {
      "passport": ">=0.6.0"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "middlewares/**/*.js",
      "models/**/*.js",
      "routes/**/*.js",
      "utils/**/*.js",
      "services/**/*.js",
      "!**/node_modules/**",
      "!**/tests/**",
      "!**/coverage/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json"
    ],
    "testTimeout": 30000,
    "verbose": true,
    "forceExit": true,
    "clearMocks": true,
    "resetMocks": true,
    "restoreMocks": true,
    "transformIgnorePatterns": [
      "node_modules/(?!(@exodus|html-encoding-sniffer)/)"
    ]
  }
}
